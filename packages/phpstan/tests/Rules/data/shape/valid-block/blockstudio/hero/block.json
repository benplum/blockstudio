{
  "name": "test/hero",
  "blockstudio": {
    "pluginDependencies": {
      "woocommerce": {
        "version": ">6"
      },
      "advanced-custom-fields": {}
    },
    "attributes": [
      { "id": "title", "type": "text" },
      {
        "type": "group",
        "attributes": [
          { "id": "summary", "type": "textarea" }
        ]
      },
      {
        "type": "tabs",
        "tabs": [
          {
            "title": "Section",
            "attributes": [
              { "id": "section", "type": "custom/section" }
            ]
          }
        ]
      },
      { "type": "custom/spacing" }
    ]
  }
}
