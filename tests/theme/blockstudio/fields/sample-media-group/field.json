{
  "$schema": "https://blockstudio.dev/schema/field",
  "name": "sample-media-group",
  "title": "Sample media group",
  "attributes": [
    {
      "id": "media_type",
      "type": "select",
      "label": "Grouped media type",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ]
    },
    {
      "id": "image_default",
      "type": "files",
      "label": "Grouped image default",
      "min": 0,
      "max": 1,
      "multiple": false,
      "allowedTypes": ["image"],
      "conditions": [
        [{ "id": "media_type", "operator": "==", "value": "image" }]
      ]
    },
    {
      "type": "group",
      "title": "Grouped image sources",
      "conditions": [
        [{ "id": "media_type", "operator": "==", "value": "image" }]
      ],
      "attributes": [
        {
          "id": "image_sources",
          "type": "repeater",
          "label": "Grouped image sources",
          "min": 0,
          "max": 12,
          "textButton": "Add grouped picture source",
          "attributes": [
            {
              "id": "source_image",
              "type": "files",
              "label": "Grouped source image",
              "min": 0,
              "max": 1,
              "multiple": false,
              "allowedTypes": ["image"]
            },
            {
              "id": "source_media",
              "type": "text",
              "label": "Grouped media query",
              "default": ""
            }
          ]
        }
      ]
    },
    {
      "id": "video_mp4",
      "type": "files",
      "label": "Grouped video MP4",
      "min": 0,
      "max": 1,
      "multiple": false,
      "allowedTypes": ["video/mp4"],
      "conditions": [
        [{ "id": "media_type", "operator": "==", "value": "video" }]
      ]
    },
    {
      "type": "group",
      "title": "Grouped video sources",
      "conditions": [
        [{ "id": "media_type", "operator": "==", "value": "video" }]
      ],
      "attributes": [
        {
          "id": "video_sources",
          "type": "repeater",
          "label": "Grouped video sources",
          "min": 0,
          "max": 12,
          "textButton": "Add grouped video source",
          "attributes": [
            {
              "id": "source_video",
              "type": "files",
              "label": "Grouped source video",
              "min": 0,
              "max": 1,
              "multiple": false,
              "allowedTypes": ["video/mp4"]
            },
            {
              "id": "source_media",
              "type": "text",
              "label": "Grouped video media query",
              "default": ""
            }
          ]
        }
      ]
    }
  ]
}
